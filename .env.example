# AEGIS AI — Root Environment Variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# Individual services also read from this file via Docker Compose's `env_file` directive
# (see infra/docker-compose/docker-compose.yml) — this is the single source of truth for local dev.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
AEGIS_ENV=local
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# PostgreSQL + TimescaleDB (DATABASE_SCHEMA.md)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=changeme_local_only
DATABASE_URL=postgresql+asyncpg://aegis:changeme_local_only@localhost:5432/aegis

# ---------------------------------------------------------------------------
# Neo4j (KNOWLEDGE_GRAPH.md)
# ---------------------------------------------------------------------------
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_local_only
NEO4J_URI=bolt://localhost:7687

# ---------------------------------------------------------------------------
# Redis (cache, Celery broker/backend)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# Kafka / Redpanda (ARCHITECTURE.md §10)
# ---------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ---------------------------------------------------------------------------
# MQTT (ARCHITECTURE.md §17.2 — sensor protocol adapter)
# ---------------------------------------------------------------------------
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# ---------------------------------------------------------------------------
# Identity & RBAC (ARCHITECTURE.md §20)
# ---------------------------------------------------------------------------
JWT_SECRET=changeme_generate_a_real_secret_before_any_shared_deployment
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
FRONTEND_BASE_URL=http://localhost:3000
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=

# ---------------------------------------------------------------------------
# AI / LLM Providers (RAG_SYSTEM.md, AGENT_ARCHITECTURE.md, RISK_FUSION_ENGINE.md)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-5
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# ---------------------------------------------------------------------------
# Service Ports (local dev — matches infra/docker-compose/docker-compose.yml)
# ---------------------------------------------------------------------------
API_GATEWAY_PORT=8000
REALTIME_GATEWAY_PORT=8001
INGESTION_GATEWAY_PORT=8002
ANOMALY_DETECTION_PORT=8003
COMPUTER_VISION_PORT=8004
PREDICTIVE_RISK_ENGINE_PORT=8005
DIGITAL_TWIN_PORT=8006
KNOWLEDGE_GRAPH_PORT=8007
RAG_SERVICE_PORT=8008
AGENTIC_ORCHESTRATOR_PORT=8009
INCIDENT_SERVICE_PORT=8010
NOTIFICATION_SERVICE_PORT=8011
IDENTITY_RBAC_PORT=8012
AUDIT_LOG_PORT=8013
IOT_SIMULATOR_PORT=8014

# ---------------------------------------------------------------------------
# Frontend (apps/web/.env.example mirrors the NEXT_PUBLIC_* subset of these)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8001
