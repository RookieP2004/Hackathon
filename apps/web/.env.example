# Frontend-specific subset of the root .env — see ../../.env.example for the full set.
# Next.js only exposes NEXT_PUBLIC_* variables to the browser bundle; keep secrets out of this file entirely.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8001

# Server-only (never NEXT_PUBLIC_*) — used exclusively by Route Handlers under
# src/app/api/auth/*, which run server-side and proxy to identity-rbac directly
# rather than routing auth traffic through the API Gateway, so the httpOnly
# refresh-token cookie is set by the same origin the browser talks to.
IDENTITY_SERVICE_URL=http://127.0.0.1:8012
